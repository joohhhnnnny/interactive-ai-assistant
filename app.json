{
  "expo": {
    "name": "Project Alab",
    "slug": "interactive-ai-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo/alab-logo.png",
    "scheme": "projectalab",
    "backgroundColor": "#f8f8f8",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/logo/alab-logo.png"
    },
    "android": {
      "userInterfaceStyle": "light",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo/alab-logo.png",
        "monochromeImage": "./assets/images/logo/alab-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.interactiveaiassistant"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo/alab-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/logo/alab-logo.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "expo-sharing",
      "expo-system-ui",
      [
        "expo-status-bar",
        {
          "hidden": false,
          "style": "dark"
        }
      ],
      [
        "expo-navigation-bar",
        {
          "enforceContrast": false,
          "hidden": false,
          "style": "dark"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Project Alab to listen to your study question.",
          "recordAudioAndroid": true,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
